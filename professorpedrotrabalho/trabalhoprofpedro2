<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz SPFC</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #ffffff; padding: 20px; }
        .quiz-container { max-width: 600px; margin: 0 auto; background: rgb(255, 255, 255); padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: #ff0000; }
        .question { margin-bottom: 20px; }
        .options label { display: block; margin-bottom: 10px; cursor: pointer; }
        button { display: block; width: 100%; padding: 10px; background-color: #ff0202; color: white; border: none; border-radius: 5px; font-size: 16px; cursor: pointer; }
        button:hover { background-color: #000000; }
        #result { margin-top: 20px; text-align: center; font-weight: bold; font-size: 1.2em; }
        .correct { color: rgb(6, 202, 6); }
        .incorrect { color: red; }
    </style>
</head>
<body>

<div class="quiz-container">
    <h1>Quiz Fã Tricolor</h1>
    <form id="quizForm">
        
        <!-- Pergunta 1 -->
        <div class="question">
            <p>1. Quantos títulos do Mundial de Clubes o SPFC possui?</p>
            <div class="options">
                <label><input type="radio" name="q1" value="errada"> 1</label>
                <label><input type="radio" name="q1" value="errada"> 2</label>
                <label><input type="radio" name="q1" value="certa"> 3</label>
                <label><input type="radio" name="q1" value="errada"> 4</label>
            </div>
        </div>

        <!-- Pergunta 2 -->
        <div class="question">
            <p>2. Em que ano o São Paulo foi campeão da Copa Sul-Americana pela primeira vez?</p>
            <div class="options">
                <label><input type="radio" name="q2" value="errada"> 2005</label>
                <label><input type="radio" name="q2" value="certa"> 2012</label>
                <label><input type="radio" name="q2" value="errada"> 2010</label>
                <label><input type="radio" name="q2" value="errada"> 2023</label>
            </div>
        </div>

        <!-- Pergunta 3 -->
        <div class="question">
            <p>3. Qual destes jogadores NÃO foram formados na base de Cotia?</p>
            <div class="options">
                <label><input type="radio" name="q3" value="errada"> Antony</label>
                <label><input type="radio" name="q3" value="errada"> Casemiro</label>
                <label><input type="radio" name="q3" value="certa"> Hernanes</label>
                <label><input type="radio" name="q3" value="errada"> David Neres</label>
            </div>
        </div>

        <div> 
          <div class="question">
          <p>4. Quem é o maior artilheiro da história do clube?</p>
        <div class="options">
            <label><input type="radio" name="q4" value="errada"> Luis Fabiano</label>
            <label><input type="radio" name="q4" value="errada"> Rogério Seni</label>
            <label><input type="radio" name="q4" value="certa"> Serginho Chulapa</label>
             </div>
         </div>

         <div>
          <div class="question">
            <p>5. Qual foi o adversário na final do Mundial de 2005?</p>
            <div class="options">
            <label><input type="radio" name="q5" value="errada"> Milan </label>
            <label><input type="radio" name="q5" value="certa"> Liverpool </label>
            <label><input type="radio" name="q5" value="errada"> Barcelona </label>
             </div>
          </div>

          <div>
            <div class="question">
            <p>6. Em que ano o São Paulo foi fundado?</p>
            <div class="options">
            <label><input type="radio" name="q6" value="certa"> 1930 </label>
            <label><input type="radio" name="q6" value="errada"> 1953 </label>
            <label><input type="radio" name="q6" value="errada"> 1940 </label>
            </div>
          </div>

          <div>
            <div class="question">
              <p>7. Qual o nome do estádio oficial do SPFC?</p>
              <div class="options">
                <label><input type="radio" name="q7" value="errada"> Arena São Paulo</label>
                <label><input type="radio" name="q7" value="errada"> MorumBIS </label>
                <label><input type="radio" name="q7" value="certa"> Cícero Pompeu de Toledo </label>
            </div>
          </div>


       <button type="button" onclick="calcularResultado()">Finalizar Quiz</button>
    </form>
    
    <div id="result"></div>
</div>

<script>
    function calcularResultado() {
        let pontuacao = 0;
        const totalPerguntas = 7;
        
        // Obter respostas
        const form = document.getElementById('quizForm');
        const formData = new FormData(form);
        
        // Verificar respostas
        for (let i = 1; i <= totalPerguntas; i++) {
            if (formData.get('q' + i) === 'certa') {
                pontuacao++;
            }
        }
        
        // Exibir Resultado
        const resultDiv = document.getElementById('result');
        resultDiv.innerHTML = `Você acertou ${pontuacao} de ${totalPerguntas} perguntas!`;
        
        if (pontuacao === totalPerguntas) {
            resultDiv.innerHTML += "<br><span class='correct'>Parabéns, Tricolor! Você sabe tudo!</span>";
        } else if (pontuacao > 0) {
            resultDiv.innerHTML += "<br><span class='incorrect'>Quase lá! Vamos estudar mais a história do clube.</span>";
        } else {
            resultDiv.innerHTML += "<br><span class='incorrect'>Ops! Tente novamente.</span>";
        }
    }
</script>

</body>
</html>
